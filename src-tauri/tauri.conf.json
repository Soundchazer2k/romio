{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Romio",
  "version": "0.1.0",
  "identifier": "app.romio.retro",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1444",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Romio",
        "width": 1100,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["data/*"]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
